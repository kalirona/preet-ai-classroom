# ==========================================
# REQUIRED CONFIGURATION
# ==========================================

# Google Gemini AI
GEMINI_API_KEY="your-gemini-api-key"

# App URL (the URL where the app is hosted)
APP_URL="http://localhost:3000"

# Server
PORT=3000
NODE_ENV=development

# Session
SESSION_SECRET=generate-a-random-64-char-string-here

# ==========================================
# DATABASE CONFIGURATION
# ==========================================

# PostgreSQL (Primary)
DATABASE_URL=postgresql://user:password@localhost:5432/skool_saas
PGHOST=localhost
PGPORT=5432
PGDATABASE=skool_saas
PGUSER=user
PGPASSWORD=password

# CloudPanel Enterprise (MySQL/MariaDB) - for CloudPanel deployment
# All DB variables reside strictly on the server to prevent exposing security keys to the frontend browser.
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_USER="cloudpanel_db_username"
DB_PASSWORD="your_secure_password"
DB_NAME="cloudpanel_database_name"

# ==========================================
# PAYMENT CONFIGURATION
# ==========================================

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret
PAYPAL_ENVIRONMENT=sandbox  # sandbox | production