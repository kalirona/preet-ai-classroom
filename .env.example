# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/skool_saas
PGHOST=localhost
PGPORT=5432
PGDATABASE=skool_saas
PGUSER=user
PGPASSWORD=password

# Session
SESSION_SECRET=generate-a-random-64-char-string-here
NODE_ENV=development

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret
PAYPAL_ENVIRONMENT=sandbox  # sandbox | production

# Server
PORT=3000
